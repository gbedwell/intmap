def check_executable(path, ex_name):
    is_file = True
    if os.path.isfile(path) and os.access(path, os.X_OK):
        if os.path.basename(path) == ex_name:
            return path
        else:
            raise Exception('Given executable does not appear to be {}.'.format(ex_name))
    else:
        is_file = False
          
    is_path = True
    if os.path.isdir(path):
        path = os.path.join(path, ex_name)
        if os.path.isfile(path) and os.access(path, os.X_OK):
            return path
        else:
            raise Exception('{} executable does not exist at the given location.'.format(ex_name))
    else:
        is_path = False
    
    if not is_file and not is_path:
        raise Exception("Nothing found at the given executable path.")
          
        
def fasta_headers(file):
    nm = []
    seen = set()
    dups = []
    for record in SeqIO.parse(file, "fasta"):
        if '-' in record.id:
            raise Exception("Hyphens ('-') were found in FASTA headers. Please replace these with another character.")
        if record.id in seen:
            dups.append(record.id)
        else:
            seen.add(record.id)
        nm.append(record.id)
    if dups:
        raise Exception(f"The following FASTA headers were found more than once: {', '.join(dups)}")
    return nm

def unique_seqs(file):
    seq_count = {}
    dups = []

    for record in SeqIO.parse(file, "fasta"):
        sequence = str(record.seq)
        if sequence in seq_count:
            if seq_count[sequence] == 1:
                dups.append(sequence)
            seq_count[sequence] += 1
        else:
            seq_count[sequence] = 1
    
    if dups:
        raise Exception(f"The following sequences were found more than once: {', '.join(dups)}")

def zipped(file):
    if os.path.exists(file):
        with open(file, 'rb') as zip_test:
            return zip_test.read(2) == b'\x1f\x8b'
    else:
        return file.endswith('.gz')
    
def open_file(filename, mode):
    if zipped(filename):
        return gzip.open(filename, mode)
    else:
        return open(filename, mode)
    
def build_barcode_matchers(bc_file, error_rate):
    matchers = []
    for record in SeqIO.parse(bc_file, "fasta"):
        seq = str(record.seq)
        max_errors = int(len(seq) * error_rate)
        pattern = regex.compile(f'({seq}){{s<={max_errors}}}', regex.IGNORECASE)
        matchers.append((record.id, pattern))
    return matchers

def match_barcode(seq, matchers):
    for name, pattern in matchers:
        if pattern.fullmatch(seq):
            return name
    return None

def parse_header_index(header):
    parts = header.strip().split()
    if len(parts) < 2:
        return None, None
    fields = parts[1].split(':')
    if len(fields) < 4:
        return None, None
    index_field = fields[3]
    if '+' in index_field:
        i1, i2 = index_field.split('+', 1)
        return i1, i2
    return index_field, None

def validate_header_index(r1_file, expect_dual):
    f = open_file(r1_file, 'rt')
    header = f.readline()
    f.close()
    if not header:
        raise Exception('Rltr file is empty.')
    i1, i2 = parse_header_index(header)
    if i1 is None:
        raise Exception(
            f'Could not parse index from FASTQ header.'
        )
    if expect_dual and i2 is None:
        raise Exception(
            f'Expected dual index (INDEX1+INDEX2) in FASTQ header but found single index only.'
        )

def match_record(si1, si2, matchers_i1, matchers_i2):
    if matchers_i1 and matchers_i2:
        m1 = match_barcode(si1, matchers_i1)
        m2 = match_barcode(si2, matchers_i2)
        if m1 and m2 and m1 == m2:
            return m1
    elif matchers_i1:
        return match_barcode(si1, matchers_i1) if si1 else None
    elif matchers_i2:
        return match_barcode(si2, matchers_i2) if si2 else None
    return None

def match_chunk(chunk, matchers_i1, matchers_i2):
    return [match_record(si1, si2, matchers_i1, matchers_i2) for si1, si2 in chunk]

def index_demux(r1, r2, i1, i2, bc_i1, bc_i2, error_rate, out_dir, out_ext, header_index = False, nthr = 1, chunk_size = 20000):
    matchers_i1 = build_barcode_matchers(bc_i1, error_rate) if bc_i1 else None
    matchers_i2 = build_barcode_matchers(bc_i2, error_rate) if bc_i2 else None

    out_handles = {}

    f_r1 = open_file(r1, 'rt')
    f_r2 = open_file(r2, 'rt') if r2 else None
    f_i1 = open_file(i1, 'rt') if i1 and not header_index else None
    f_i2 = open_file(i2, 'rt') if i2 and not header_index else None

    try:
        while True:
            records = []
            indices = []

            for _ in range(chunk_size):
                h1 = f_r1.readline()
                if not h1:
                    break
                s1 = f_r1.readline()
                o1 = f_r1.readline()
                q1 = f_r1.readline()

                r2_block = None
                if f_r2:
                    h2 = f_r2.readline()
                    s2 = f_r2.readline()
                    o2 = f_r2.readline()
                    q2 = f_r2.readline()
                    r2_block = (h2, s2, o2, q2)

                if header_index:
                    si1, si2 = parse_header_index(h1)
                else:
                    si1 = None
                    if f_i1:
                        f_i1.readline()
                        si1 = f_i1.readline().strip()
                        f_i1.readline()
                        f_i1.readline()

                    si2 = None
                    if f_i2:
                        f_i2.readline()
                        si2 = f_i2.readline().strip()
                        f_i2.readline()
                        f_i2.readline()

                records.append(((h1, s1, o1, q1), r2_block))
                indices.append((si1, si2))

            if not records:
                break

            if nthr == 1:
                samples = match_chunk(indices, matchers_i1, matchers_i2)
            else:
                split_size = max(1, len(indices) // nthr)
                indices_split = [indices[i:i + split_size] for i in range(0, len(indices), split_size)]
                results = Parallel(n_jobs = min(len(indices_split), nthr))(
                    delayed(match_chunk)(
                        chunk = indices_split[entry],
                        matchers_i1 = matchers_i1,
                        matchers_i2 = matchers_i2
                    )
                    for entry in range(len(indices_split))
                )
                samples = [s for batch in results for s in batch]

            for sample, (r1_block, r2_block) in zip(samples, records):
                if not sample:
                    continue

                if sample not in out_handles:
                    out_handles[sample] = {
                        'Rltr': open_file(os.path.join(out_dir, f'{sample}_Rltr{out_ext}'), 'wt')
                    }
                    if f_r2:
                        out_handles[sample]['Rlink'] = open_file(
                            os.path.join(out_dir, f'{sample}_Rlink{out_ext}'), 'wt'
                        )

                out_handles[sample]['Rltr'].write(r1_block[0] + r1_block[1] + r1_block[2] + r1_block[3])
                if f_r2 and r2_block:
                    out_handles[sample]['Rlink'].write(r2_block[0] + r2_block[1] + r2_block[2] + r2_block[3])

    finally:
        f_r1.close()
        if f_r2:
            f_r2.close()
        if f_i1:
            f_i1.close()
        if f_i2:
            f_i2.close()
        for handles in out_handles.values():
            for fh in handles.values():
                fh.close()

def validate_file(file, description):
    if not file:
        raise Exception(f'{description} must be defined.')
    if not os.path.isfile(file):
        raise Exception(f'{description} is not a valid file.')
    unique_seqs(file = file)
    return fasta_headers(file = file)
  
def generate_dmx_command(adapter_option, d1, r1, d2 = None, r2 = None, discard_untrimmed = True):
    if discard_untrimmed:
        discard = "--discard-untrimmed"
    else:
        discard = ""

    base_cmd = (f'{args.cutadapt_path} -e {args.error_rate} --no-indels {discard} --action=none -j {args.nthr} '
                f'{adapter_option} -o {d1}')
    if d2:
        base_cmd += f' -p {d2}'
    if args.no_index:
        base_cmd += ' --no-index'
    if r2:
        base_cmd += f' {r1} {r2}'
    else:
        base_cmd += f' {r1}'
    return base_cmd

def process_file_match(file_match_path, dmx_dir, tmp_dir, nm1):
    keep_nm, new_nm = [], []
    with open(file_match_path, 'r') as file:
        delim = ',' if ',' in file.readline() else '\t'
        file.seek(0)
        for line in file:
            names = line.strip().split(delim)
            if len(names) != 2:
                raise Exception('file_match line had more than two entries.')
            keep_nm.append(names[0].replace(' ', ''))
            new_nm.append(names[1].replace(' ', ''))

    all_nm = [f'{i}_*' if args.ltr_only or args.linker_only else f'{i}-{i}_*' for i in nm1]
    keep = [file for i in keep_nm for file in glob.glob(f'{tmp_dir}/{i}')]

    for i, file in enumerate(keep):
        shutil.move(file, os.path.join(dmx_dir, new_nm[i]))

    for other_nm in all_nm:
        for tmp_file in glob.glob(f'{tmp_dir}/{other_nm}'):
            os.remove(tmp_file)

def rename_and_cleanup_files(dmx_dir, tmp_dir, nm1):
    keep_nm = [f'{i}_*' if args.ltr_only or args.linker_only else f'{i}-{i}_*' for i in nm1]
    keep = [file for i in keep_nm for file in glob.glob(f'{tmp_dir}/{i}')]

    for file in keep:
        pattern = r'^(.+?)_(R(?:ltr|link))\.(fq|fq\.gz)$' if args.ltr_only or args.linker_only else r'^(.+?)-(.+?)_(R(?:ltr|link))\.(fq|fq\.gz)$'
        pmatch = regex.match(pattern, os.path.basename(file))
        new_name = f"{pmatch.group(1)}_{pmatch.group(2)}.{pmatch.group(3)}" if args.ltr_only or args.linker_only else f"{pmatch.group(1)}_{pmatch.group(3)}.{pmatch.group(4)}"
        shutil.move(file, os.path.join(dmx_dir, new_name))

    if tmp_dir == os.path.join(dmx_dir, 'tmp'):
        shutil.rmtree(tmp_dir)
        
trans_table = bytes.maketrans(b"acgtumrwsykvhdbnACGTUMRWSYKVHDBN", 
                              b"TGCAAKYWSRMBDHVNTGCAAKYWSRMBDHVN")

def revcomp(seq):
    return seq.translate(trans_table)[::-1]
  
def linked_adapters(bc_ltr, bc_linker):
    ltr_records = [(rec.id, str(rec.seq)) for rec in SeqIO.parse(bc_ltr, "fasta")]
    linker_records = [(rec.id, str(rec.seq)) for rec in SeqIO.parse(bc_linker, "fasta")]
    if len(ltr_records) != len(linker_records):
        raise Exception(
            f'LTR and linker fasta files must have the same number of entries.'
        )
    return ' '.join(
        f'-g {name}=^{ltr}...{revcomp(linker)}$'
        for (name, ltr), (_, linker) in zip(ltr_records, linker_records)
    )
    
def revcomp_from_file(bc_file):
    records = [(r.id, revcomp(str(r.seq))) for r in SeqIO.parse(bc_file, "fasta")]
    return ' '.join(f'-a {name}={seq}$' for name, seq in records)

if __name__ == "__main__":
    
    args.r1 = args.ltr_reads
    args.r2 = args.linker_reads
    
    # Header indexes or file-based indexes
