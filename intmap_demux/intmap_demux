                raise Exception('--header_index cannot be used with -i1/-i2. Index sequences '
                                'are read from the FASTQ headers instead.')
            if not args.bc_ltr and not args.bc_linker:
                raise Exception('At least one of bc_ltr or bc_linker must be provided with --header_index.')
        else:
            if args.i1 and not args.bc_ltr:
                raise Exception('bc_ltr is required when i1 is provided.')
            if args.i2 and not args.bc_linker:
                raise Exception('bc_linker is required when i2 is provided.')

        if args.bc_ltr:
            nm1 = validate_file(args.bc_ltr, 'bc_ltr')
        if args.bc_linker:
            nm_i2 = validate_file(args.bc_linker, 'bc_linker')
            if args.bc_ltr:
                if nm1 != nm_i2:
                    raise ValueError('The fasta headers in bc_ltr and bc_linker must match.')
            else:
                nm1 = nm_i2

        if args.header_index:
            expect_dual = args.bc_ltr is not None and args.bc_linker is not None
            validate_header_index(args.r1, expect_dual)

        soft_limit, _ = resource.getrlimit(resource.RLIMIT_NOFILE)
        n_samples = len(nm1)
        files_needed = n_samples * (2 if args.r2 else 1)
        overhead = 10
        if files_needed + overhead > soft_limit:
            raise Exception(
                f"\nToo many output files: {n_samples} sample(s) * "
                f"{'2 (paired-end)' if args.r2 else '1 (single-end)'} = {files_needed} files. "
                f"ulimit -n is {soft_limit}. "
                f"Increase with: ulimit -S -n {files_needed + overhead + 10}\n"
            )

        curr_dir = os.getcwd()
        dmx_dir = os.path.join(curr_dir, 'demux')
        if not os.path.exists(dmx_dir):
            os.makedirs(dmx_dir)

        if zipped(file=args.r1):
            out_ext = '.fq.gz'
        else:
            out_ext = '.fq'

        index_demux(
            r1 = args.r1, r2 = args.r2,
            i1 = args.i1, i2 = args.i2,
            bc_i1 = args.bc_ltr if (args.i1 or args.header_index) else None,
            bc_i2 = args.bc_linker if (args.i2 or args.header_index) else None,
            error_rate = args.error_rate,
            out_dir = dmx_dir, out_ext = out_ext,
            header_index = args.header_index,
            nthr = args.nthr
        )

        if args.file_match:
            keep_nm, new_nm = [], []
            with open(args.file_match, 'r') as f:
                delim = ',' if ',' in f.readline() else '\t'
                f.seek(0)
                for line in f:
                    names = line.strip().split(delim)
                    if len(names) != 2:
                        raise Exception('file_match line must have exactly two entries.')
                    keep_nm.append(names[0].replace(' ', ''))
                    new_nm.append(names[1].replace(' ', ''))
            for old_name, new_name in zip(keep_nm, new_nm):
                for match in glob.glob(os.path.join(dmx_dir, f'{old_name}_*')):
                    suffix = os.path.basename(match)[len(old_name):]
                    shutil.move(match, os.path.join(dmx_dir, f'{new_name}{suffix}'))

        sys.exit()

    # In-line indexes
    if args.r1 and not args.r2 and not args.ltr_only:
        args.ltr_only = True

    if args.ltr_only and args.linker_only:
        raise Exception('ltr_only and linker_only cannot both be True.')

    if not args.ltr_only and not args.linker_only:
        nm1 = validate_file(args.bc_ltr, 'bc_ltr')
        nm2 = validate_file(args.bc_linker, 'bc_linker')
        if nm1 != nm2:
            raise ValueError('The fasta headers in bc_ltr and bc_linker must match.')
    elif args.ltr_only:
        nm1 = validate_file(args.bc_ltr, 'bc_ltr')
    else:
        nm1 = validate_file(args.bc_linker, 'bc_linker')
        
    if args.cutadapt_path != 'cutadapt':
        args.cutadapt_path = check_executable(path = args.cutadapt_path, ex_name = 'cutadapt')
        
    # If hanging is happening, it is likely because too many files are open
    # See: https://github.com/marcelm/cutadapt/issues/613
    soft_limit, _ = resource.getrlimit(resource.RLIMIT_NOFILE)

    if not args.ltr_only and not args.linker_only:
        n_combinations = len(nm1) * len(nm2)
        files_needed = n_combinations * (2 if args.r2 else 1)
    elif args.ltr_only or args.linker_only:
        n_combinations = len(nm1)
        files_needed = n_combinations * (2 if args.r2 else 1)

    overhead = 10
    if files_needed + overhead > soft_limit:
        raise Exception(
            f"\nToo many output files required: {n_combinations} barcode combination(s) * "
            f"{'2 (paired-end)' if args.r2 else '1 (single-end)'} ~= {files_needed} files. "
            f"ulimit -n is {soft_limit} (overhead ~{overhead}). "
            f"Increase with: ulimit -S -n {files_needed + overhead + 10}\n"
        )

    curr_dir = os.getcwd()

    dmx_dir = os.path.join(curr_dir, f'demux')
    if not os.path.exists(dmx_dir):
        os.makedirs(dmx_dir)
    
    if not args.keep_all and not args.ltr_only and not args.linker_only:
        tmp_dir = os.path.join(dmx_dir, f'tmp')
        if not os.path.exists(tmp_dir):
            os.makedirs(tmp_dir)
    else:
        tmp_dir = dmx_dir
        
    if zipped(file = args.r1):
        out_ext = '.fq.gz'
    else:
        out_ext = ".fq"
    
    if args.r1 and args.r2:
        swap = False
        if not args.ltr_only and not args.linker_only:
            d1 = os.path.join(tmp_dir, f'{{name1}}-{{name2}}_Rltr{out_ext}')
            d2 = os.path.join(tmp_dir, f'{{name1}}-{{name2}}_Rlink{out_ext}')
            adapter_option = f'-g ^file:{args.bc_ltr} -G ^file:{args.bc_linker}'
            discard_untrimmed = True
        elif args.ltr_only:
            d1 = os.path.join(tmp_dir, f'{{name}}_Rltr{out_ext}')
            d2 = os.path.join(tmp_dir, f'{{name}}_Rlink{out_ext}')
            adapter_option = f'-g ^file:{args.bc_ltr}'
            discard_untrimmed = False
        elif args.linker_only:
            d1 = os.path.join(tmp_dir, f'{{name}}_Rltr{out_ext}')
            d2 = os.path.join(tmp_dir, f'{{name}}_Rlink{out_ext}')
            adapter_option = f'-g ^file:{args.bc_linker}'
            swap = True
            discard_untrimmed = False

        dmx_cmd = generate_dmx_command(
            adapter_option = adapter_option, 
            d1 = d1 if not swap else d2, 
            r1 = args.r1 if not swap else args.r2,
            d2 = d2 if not swap else d1, 
            r2 = args.r2 if not swap else args.r1,
            discard_untrimmed = discard_untrimmed
        )
        
    elif args.r1 and not args.r2:
        d1 = os.path.join(dmx_dir, f'{{name}}_Rltr{out_ext}')
        if args.bc_ltr and args.bc_linker:
            adapter_option = linked_adapters(args.bc_ltr, args.bc_linker)
        elif args.three_prime:
            if args.bc_ltr:
                adapter_option = revcomp_from_file(args.bc_ltr)
            else:
                adapter_option = revcomp_from_file(args.bc_linker)
        else:
            adapter_option = f'-g ^file:{args.bc_ltr}'

        dmx_cmd = generate_dmx_command(
            adapter_option = adapter_option, 
            d1 = d1, 
            r1 = args.r1,
            discard_untrimmed = True
        )

    subprocess.call(dmx_cmd, shell = True)
        
    if not args.keep_all:
        if args.file_match:
            process_file_match(args.file_match, dmx_dir, tmp_dir, nm1)
        else:
            rename_and_cleanup_files(dmx_dir, tmp_dir, nm1)